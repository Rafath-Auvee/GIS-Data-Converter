{
  "info": {
    "name": "GIS Data Converter",
    "_postman_id": "8f1a1a1a-2222-4d3d-9a1a-gisdataconverter",
    "description": "Full API for the GIS Data Converter service.\n\n**Setup:** import this collection, set the `base_url` variable if not localhost, then run any *Upload* request \u2014 it auto-saves the returned `task_id`, so *Get task status* / *Get task result* / *Download output* work with no manual copy-paste.\n\nEach upload points at the matching sample in the repo's `test cases/` folder. If Postman can't find a file, re-select it in the request's Body tab (formdata `file` row).",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:8000"
    },
    {
      "key": "task_id",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "System",
      "item": [
        {
          "name": "Health check",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/health",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "health"
              ]
            },
            "description": "Service health check."
          }
        }
      ]
    },
    {
      "name": "Core conversions (mandatory Top 5)",
      "item": [
        {
          "name": "GeoJSON \u2192 CSV",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 202) {",
                  "  const id = pm.response.json().task_id;",
                  "  pm.collectionVariables.set('task_id', id);",
                  "  console.log('Saved task_id =', id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/upload",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "upload"
              ]
            },
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "file",
                  "type": "file",
                  "src": "test cases/geojson_to_csv/regions.geojson"
                },
                {
                  "key": "conversion",
                  "value": "geojson_to_csv",
                  "type": "text"
                }
              ]
            },
            "description": "Upload the `test cases/geojson_to_csv` sample and queue a `geojson_to_csv` job. Saves the returned task_id to the `task_id` collection variable."
          }
