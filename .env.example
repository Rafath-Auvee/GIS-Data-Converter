# ============================================================================
# GIS Data Converter - environment configuration
# Copy this file to ".env" (cp .env.example .env), then run: docker compose up -d
# The defaults below work out of the box for local development.
# ============================================================================

# --- Postgres database (task metadata / conversion history) -----------------
POSTGRES_USER=gis
POSTGRES_PASSWORD=gis_password
POSTGRES_DB=gis_converter
DATABASE_URL=postgresql+psycopg://gis:gis_password@db:5432/gis_converter

# --- MinIO object storage (uploaded inputs + converted outputs) -------------
# Console UI:  http://localhost:9001   (login with the two values below)
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=gis-data
MINIO_SECURE=false

# --- Celery + Redis (background conversion worker queue) --------------------
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# --- Upload limit -----------------------------------------------------------
MAX_UPLOAD_SIZE_MB=200

# --- pgAdmin (browse the Postgres database in a web UI) ---------------------
# Web UI:  http://localhost:5050   (login with the two values below)
PGADMIN_DEFAULT_EMAIL=admin@admin.com
PGADMIN_DEFAULT_PASSWORD=admin
